{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Quick",
            "type": "shell",
            "command": "powershell",
            "args": [
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              "${workspaceFolder}\\build\\buildInteractive.ps1"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "showReuseMessage": false,
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "powershell",
            "args": [
              "-ExecutionPolicy",
              "Bypass",
              "-File",
              "${workspaceFolder}\\build\\build.ps1",
              "-Preset",
              "Release"
            ],
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "clear": true
            },
            "problemMatcher": []
        }
    ]
}