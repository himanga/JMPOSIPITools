			dtPoints:Desc Search << Set Values( {"" } ),
			dtPoints:Friendly Name << Set Values( {"" } ),
			dtPoints:Return value << Set Values( {"Yes" } ),
			dtPoints:Return svalue << Set Values( {"No" } ),
			dtPoints:Return status << Set Values( {"No" } )
		}
	},
	{
