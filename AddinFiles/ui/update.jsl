			dtPoints << Select Where(1),
			dtPoints << Delete Rows,
			dtPoints << Add Rows(10),
			dtPoints:Tag Search << Set Values( {"sinusoid" } ),
			dtPoints:Desc Search << Set Values( {"" } ),
