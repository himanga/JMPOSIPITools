ns = Namespace( "com.github.himanga.JMPOSIPITools" || ".addinnamespace" );

ut test( "timeUtils", "UrlEncode", Expr(

    //
    // Basic correctness
    //

    ut assert value(
        ns:UrlEncode( "hello world" ),
        ut equal to( "hello%20world" ),
        "Encodes space as %20"
    );

    ut assert value(
        ns:UrlEncode( "100%" ),
        ut equal to( "100%25" ),
        "Encodes percent sign"
    );

    ut assert value(
        ns:UrlEncode( "a+b" ),
        ut equal to( "a%2Bb" ),
        "Encodes plus sign"
    );

    ut assert value(
        ns:UrlEncode( "A&B" ),
        ut equal to( "A%26B" ),
        "Encodes ampersand"
    );

    ut assert value(
        ns:UrlEncode( "(test)" ),
        ut equal to( "%28test%29" ),
        "Encodes parentheses"
    );


    //
    // Ordering / interaction
    //

    ut assert value(
        ns:UrlEncode( "% +" ),
        ut equal to( "%25%20%2B" ),
        "Encodes % before other characters"
    );


    //
    // Identity cases
    //

    ut assert value(
        ns:UrlEncode( "abcXYZ123" ),
        ut equal to( "abcXYZ123" ),
        "Leaves unreserved characters unchanged"
    );


    //
    // Error handling
    //

    ut assert that(
        Expr( ns:UrlEncode() ),
        ut throws( ut anything() ),
        "Throws when argument is missing"
    );

    ut assert that(
        Expr( ns:UrlEncode( {} ) ),
        ut throws( ut anything() ),
        "Throws when argument is not a string"
    );

    ut assert that(
        Expr( ns:UrlEncode( 5 ) ),
        ut throws( ut anything() ),
        "Throws when argument is numeric"
    );

));


// Network-dependent tests - conn built once in setup
timeUtilsTestCase = ut test case( "timeUtils" )
    << Setup( Expr(
        conn = ns:MakeConnection(
            ns:UserPref["Base_Url"],
            ns:UserPref["PI_Server"],
            0,  //live
            num( ns:UserPref["Max_Rows"] ),
            "no" //allow insecure
        );
    ));

ut test( timeUtilsTestCase, "ParseDateString", Expr(

    expectedLocal = ParseDate( "2024-01-02T12:34:56" ) + ns:GetLocalTimeZoneDifference( conn );

    ut assert value(
        ns:ParseDateString( conn, "2024-01-02T12:34:56Z" ),
        ut equal to( expectedLocal ),
        "Z-suffix timestamps should convert from UTC to local time"
    );

    ut assert value(
        ns:ParseDateString( conn, "2024-01-02T12:34:56" ),
        ut equal to( ParseDate( "2024-01-02T12:34:56" ) ),
        "Non-Z timestamps should be parsed directly"
    );

    ut assert that(
        Expr( ns:ParseDateString( conn ) ),
        ut throws( ut anything() ),
        "Function should error when argument missing"
    );

    ut assert that(
        Expr( ns:ParseDateString( conn, 1234 ) ),
        ut throws( ut anything() ),
        "Function should error when argument is not a string"
    );

    ut assert that(
        Expr( ns:ParseDateString( conn, "" ) ),
        ut throws( ut anything() ),
        "Empty string throws"
    );

));

ut test( timeUtilsTestCase, "ToDateString", Expr(

    ut assert that(
        Expr( Ends With( ns:ToDateString( conn, Today() ), "Z" ) ),
        ut equal to( 1 ),
        "Appends Z suffix for UTC"
    );

    ut assert that(
        Expr( Length( ns:ToDateString( conn, Today() ) ) ),
        ut equal to( 20 ),
        "Returns ISO-8601 length string"
    );

    ut assert that(
        Expr(
            ns:ToDateString( conn,
                Date DMY( 1, 1, 2020 ) + in hours(12)
            )
        ),
        ut equal to(
            Format Date(
                Date DMY( 1, 1, 2020 ) + in hours(12) - ns:GetLocalTimeZoneDifference( conn ),
                "yyyy-mm-ddThh:mm:ss"
            ) || "Z"
        ),
        "Returns the right date for a known time"
    );

    ut assert that(
        Expr( ns:ToDateString( conn ) ),
        ut throws( ut anything() ),
        "Throws when argument is missing"
    );

    ut assert that(
        Expr( ns:ToDateString( conn, "2020-01-01" ) ),
        ut throws( ut anything() ),
        "Throws on non-numeric input"
    );

));

ut test( timeUtilsTestCase, "GetLocalTimeZoneDifference", Expr(

    // Clear cache specifically for this test to exercise cold-cache path
    If(
        Contains( conn, "timeDifference" ),
        Remove From( conn, Loc( conn << Get Keys, "timeDifference" ) )
    );

    ut assert that(
        Expr( ns:GetLocalTimeZoneDifference( conn ) ),
        ut typed as( "Number" ),
        "Returns numeric timezone offset"
    );

    first  = ns:GetLocalTimeZoneDifference( conn );
    second = ns:GetLocalTimeZoneDifference( conn );

    ut assert value(
        first,
        ut equal to( second ),
        "Returns cached value on subsequent calls"
    );

));

ut test( timeUtilsTestCase, "ComputeLocalTimeZoneDifference", Expr(

    ut assert that(
        Expr( ns:ComputeLocalTimeZoneDifference( Today() + InHours(3.1) ) ),
        ut equal to( -InHours(3) ),
        "Rounds to nearest whole hour"
    );

    ut assert that(
        Expr( ns:ComputeLocalTimeZoneDifference( Today() + InHours(2.9) ) ),
        ut equal to( -InHours(3) ),
        "Rounds up to whole hour"
    );

    ut assert that(
        Expr( ns:ComputeLocalTimeZoneDifference( Today() + InHours(2.1) ) ),
        ut equal to( -InHours(2) ),
        "Rounds down to whole hour"
    );

    // 30-minute offset zones (e.g. India UTC+5:30, Newfoundland UTC-3:30)
    ut assert that(
        Expr( ns:ComputeLocalTimeZoneDifference( Today() + InHours(5.5) ) ),
        ut equal to( -InHours(5.5) ),
        "Correctly handles 30-minute offset zones"
    );

    // 45-minute offset zones (e.g. Nepal UTC+5:45)
    ut assert that(
        Expr( ns:ComputeLocalTimeZoneDifference( Today() + InHours(5.75) ) ),
        ut equal to( -InHours(5.75) ),
        "Correctly handles 45-minute offset zones"
    );

    // 15-minute boundary
    ut assert that(
        Expr( ns:ComputeLocalTimeZoneDifference( Today() + InMinutes(7) ) ),
        ut equal to( 0 ),
        "Rounds to zero within 7 minutes of UTC"
    );

    ut assert that(
        Expr( ns:ComputeLocalTimeZoneDifference( Today() + InMinutes(8) ) ),
        ut equal to( -InMinutes(15) ),
        "Rounds to 15 minutes at 8 minutes past boundary"
    );

));

ut test( timeUtilsTestCase, "PiTimeToTimestamp", Expr(

    ut assert that(
        Expr( ns:PiTimeToTimestamp( conn ) ),
        ut throws( ut anything() ),
        "Missing piTimes argument throws"
    );

    ut assert that(
        Expr( ns:PiTimeToTimestamp( conn, "*" ) ),
        ut throws( ut anything() ),
        "Non-list input throws"
    );

    ut assert that(
        Expr( Type( ns:PiTimeToTimestamp( conn, {"*"} ) ) ),
        ut equal to( "List" ),
        "Returns a list when given a list"
    );

    ut assert that(
        Expr( Eval( Eval Expr( Type( Expr(ns:PiTimeToTimestamp( conn, {"*"}, 1 ))[1] ) ) ) ),
        ut any of( { ut equal to( "Number" ), ut equal to( "Integer" ) } ),
        "Parsed timestamps return numeric JMP dates"
    );

));

ut test( timeUtilsTestCase, "PiDurationToSeconds", Expr(

    ut assert that(
        Expr( ns:PiDurationToSeconds( conn ) ),
        ut throws( ut anything() ),
        "Missing piDurations argument throws"
    );

    ut assert that(
        Expr( ns:PiDurationToSeconds( conn, "1h" ) ),
        ut throws( ut anything() ),
        "Non-list input throws"
    );

    ut assert that(
        Expr( Type( ns:PiDurationToSeconds( conn, {"1h"} ) ) ),
        ut equal to( "List" ),
        "Returns list"
    );

    ut assert that(
        Expr( N Items( ns:PiDurationToSeconds( conn, {"1h", "30m"} ) ) ),
        ut equal to( 2 ),
        "Preserves input cardinality"
    );

    ut assert that(
        Expr(
            Eval( Eval Expr( Expr(ns:PiDurationToSeconds( conn, {"1h"} ))[1] ) )
        ),
        ut all of( { ut greater than( 3500 ), ut less than( 3700 ) } ),
        "One hour approximates 3600 seconds"
    );

    ut assert that(
        Expr(
            Eval( Eval Expr( Expr(ns:PiDurationToSeconds( conn, {"1h-30m"} ))[1] ) )
        ),
        ut all of( { ut greater than( 1700 ), ut less than( 1900 ) } ),
        "1h-30m approximates 1800 seconds"
    );

));
