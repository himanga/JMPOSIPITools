ns = Namespace( "com.github.himanga.JMPOSIPITools" || ".addinnamespace" );

ut test( "addinToolstest", "assignparsename", Expr(

    ut assert that(
        Expr( 
            local( {foo},
                ns:assignparsename( "foo", "bar" );
                foo;
            )
        ),
        ut equal to( "bar" ),
        "assigns value to variable'"
    );

    ut assert that(
        Expr( ns:assignparsename( ) ),
        ut throws( ut anything() ),
        "Function should error when arguments missing"
    );

    ut assert that(
        Expr( ns:assignparsename( "left" ) ),
        ut throws( ut as lowercase( ut all of( {ut contains( "right" ), ut contains( "missing") } ) ) ),
        "Function should error when right argument missing"
    );

    ut assert that(
        Expr( ns:assignparsename( , "right" ) ),
        ut throws( ut as lowercase( ut all of( {ut contains( "left" ), ut contains( "missing") } ) ) ),
        "Function should error when left argument missing"
    );
));

//
// Tests for TryAppendError (updated for stillthrow handling)
//

ut test("addinToolstest", "TryAppendError", Expr(

    // ------------------------------------------------------
    // 1. Basic success: expression succeeds & return value OK
    // ------------------------------------------------------
    loaderrors = {};
    ut assert that(
        Expr( ns:TryAppendError( Expr(10 + 5), Expr(loaderrors), "No error expected" ) ),
        ut equal to(15),
        "Should return evaluated value when expression succeeds"
    );

    ut assert that(
        Expr( loaderrors ),
        ut equal to({}),
        "Should not append any errors on success"
    );

    // --------------------------------------------------------
    // 2. Append behavior: expression FAILS → append to list
    // --------------------------------------------------------
    ut assert that( Expr(
        loaderrors = {};
        ns:TryAppendError(
            Expr( 1 = 2 ), 
            Expr(loaderrors), 
            "Failure occurred"
        );
        loaderrors[1] ),
        ut contains("Failure occurred"),
        "Should append prefixed error message"
    );

    // ---------------------------------------------------------
    // 3. stillthrow = 1 → error appended but THEN re-thrown
    // ---------------------------------------------------------
    loaderrors = {};
    ut assert that(
        Expr(
            ns:TryAppendError(
                Expr(1 = 2),
                Expr(loaderrors),
                "Fail with rethrow",
                1        // stillthrow = 1
            )
        ),
        ut throws( ut anything() ),
        "Should rethrow error if stillthrow = 1"
    );

    ut assert that(
        expr( loaderrors[1] ),
        ut contains("Fail with rethrow"),
        "Error should still be appended before rethrow"
    );

    // ---------------------------------------------------------
    // 4. stillthrow must be integer
    // ---------------------------------------------------------
    loaderrors = {};
    ut assert that(
        Expr(
            ns:TryAppendError(
                Expr(1=2),
                Expr(loaderrors),
                "Bad stillthrow",
                "notint"
            )
        ),
        ut throws( ut anything() ),
        "Should error when stillthrow is not an integer"
    );

    // ---------------------------------------------------------
    // 5. stillthrow must be 0 or 1
    // ---------------------------------------------------------
    loaderrors = {};
    ut assert that(
        Expr(
            ns:TryAppendError(
                Expr(1=2),
                Expr(loaderrors),
                "Bad stillthrow val",
                2     // invalid
            )
        ),
        ut throws( ut anything() ),
        "Should error when stillthrow is not 0 or 1"
    );

    // ---------------------------------------------------------
    // 6. lst must be a list
    // ---------------------------------------------------------
    ut assert that(
        Expr( ns:TryAppendError( Expr(1=2), Expr("notalist"), "prepend" ) ),
        ut throws( ut anything() ),
        "Should error when lst is not a list"
    );

    // ---------------------------------------------------------
    // 7. prepend must be a string
    // ---------------------------------------------------------
    loaderrors = {};
    ut assert that(
        Expr( ns:TryAppendError( Expr(1=2), Expr(loaderrors), 123 ) ),
        ut throws( ut anything() ),
        "Should error when prepend is not a string"
    );

    // ---------------------------------------------------------
    // 8. Missing arguments should error
    // ---------------------------------------------------------
    ut assert that(
        Expr( ns:TryAppendError() ),
        ut throws( ut anything() ),
        "Missing all arguments should error"
    );

    ut assert that(
        Expr( ns:TryAppendError( Expr(1=2) ) ),
        ut throws( ut anything() ),
        "Missing lst and prepend should error"
    );

    ut assert that(
        Expr( ns:TryAppendError( Expr(1=2), Expr(loaderrors) ) ),
        ut throws( ut anything() ),
        "Missing prepend should error"
    );

    // ---------------------------------------------------------
    // 9. Ensure original exception message is included
    // ---------------------------------------------------------
    loaderrors = {};
    ut assert that( Expr( 
            loaderrors = {};
            ns:TryAppendError(
                Expr( Throw("XYZ") ),
                Expr(loaderrors),
                "Prefix"
            );
            loaderrors[1];
        ),
        ut contains("XYZ"),
        "Should include the underlying exception message"
    );

    // ---------------------------------------------------------
    // 10. When stillthrow=0 and error occurs:
    //     The returned value should NOT be an exception
    // ---------------------------------------------------------
    loaderrors = {};
    ut assert that( Expr(
        ns:TryAppendError(
            Expr( Throw("Oops") ),
            Expr(loaderrors),
            "Some prefix",
            0
        )),
        ut no throw(),
        "When stillthrow=0 function should swallow exception and return a value"
    );

));

ut test( "addinToolstest", "ziplists", Expr(

    // List of lists (numeric keys), returning arrays
    ut assert that(
        Expr( ns:ziplists( { {"a","b"}, {11, 12} } ) ),
        ut equal to(
            eval list({
				associative array({{1,"a"},{2,11}}),
				associative array({{1,"b"},{2,12}})
			});
        ),
        "Zips unnamed lists using numeric keys"
    );

    // List of lists (numeric keys), returning lists
    ut assert that(
        Expr( ns:ziplists( { {"a","b"}, {11, 12} }, "lists" ) ),
        ut equal to( { { "a", 11 }, { "b", 12 } } ),
        "Zips unnamed lists using numeric keys returning lists"
    );
    
    // Associative array of lists (named keys)
    ut assert that(
        Expr( ns:ziplists(
            Associative Array({
				{"letters",  {"a","b"} },
				{"numbers", {11,12} }
			} )
        ) ),
        ut equal to(
            eval list({
				associative array({{"letters","a"},{"numbers",11}}),
				associative array({{"letters","b"},{"numbers",12}})
			});
        ),
        "Zips named lists using associative array keys"
    );

    // Wrong return type
    ut assert that(
        Expr( ns:ziplists( { {"a","b"}, {11, 12} }, "wrong" ) ),
        ut throws( ut contains( "returntype" ) ),
        "Errors when returntype is wrong type"
    );

    // Missing argument
    ut assert that(
        Expr( ns:ziplists() ),
        ut throws( ut anything() ),
        "Errors when argument is missing"
    );

    // Invalid argument type
    ut assert that(
        Expr( ns:ziplists( 123 ) ),
        ut throws( ut contains( "must be a list" ) ),
        "Errors when argument is not a list or associative array"
    );

    // Non-list element
    ut assert that(
        Expr( ns:ziplists( { {"a","b"}, 3 } ) ),
        ut throws( ut contains( "must be lists" ) ),
        "Errors when an element is not a list"
    );

    // Length mismatch
    ut assert that(
        Expr( ns:ziplists( { {"a","b"}, {1} } ) ),
        ut throws( ut contains( "same length" ) ),
        "Errors when lists have different lengths"
    );

));

ut test( "addinToolsTest", "padnum", Expr(

    ut assert that(
		expr( ns:padnum( 0, 1 ) ),
		ut equal to( "0" ),
		"Pads zero with leading zero"
    );

    ut assert that(
		expr( ns:padnum( 0 ) ),
		ut equal to( "00" ),
		"Pads zero with leading zero"
    );

    ut assert that(
		expr( ns:padnum( 0, 3 ) ),
		ut equal to( "000" ),
		"Pads zero with leading zero"
    );

    ut assert that(
        expr( ns:padnum( 3 ) ),
        ut equal to( "03" ),
        "Pads single-digit numbers with leading zero"
    );

    ut assert that(
        expr( ns:padnum( -3 ) ),
        ut equal to( "-03" ),
        "Pads negative numbers"
    );

    ut assert that(
        expr( ns:padnum( 9 ) ),
        ut equal to( "09" ),
        "Pads highest single-digit number"
    );

    ut assert that(
        expr( ns:padnum( 10 ) ),
        ut equal to( "10" ),
        "Does not pad two-digit numbers"
    );

    ut assert that(
        expr( ns:padnum( 142 ) ),
        ut equal to( "142" ),
        "Leaves larger numbers unchanged"
    );

    ut assert that(
        expr( ns:padnum( 142, 15 ) ),
        ut equal to( "000000000000142" ),
        "Pads wide numebrs"
    );

    ut assert that(
        Expr( ns:padnum( ) ),
        ut throws( ut anything() ),
        "Function should error when argument is missing"
    );
));